# ============================================================
# Majordom Financiar — Configurare
# Copiază acest fișier ca .env și completează valorile
# ============================================================

# --- Telegram Bot ---
# Obține token de la @BotFather pe Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# ID-ul tău Telegram (securitate — doar tu poți folosi botul)
# Cum îl afli: trimite /start la @userinfobot pe Telegram
# Mai mulți utilizatori: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=123456789

# --- Actual Budget ---
ACTUAL_BUDGET_URL=http://actual-budget:5006
ACTUAL_BUDGET_PASSWORD=your_password_here
# Sync ID: Actual Budget → Settings → Advanced → Sync ID
ACTUAL_BUDGET_SYNC_ID=your_sync_id_here

# --- Ollama (AI Vision pentru bonuri) ---
# Dacă Ollama rulează în Docker Compose (default):
OLLAMA_URL=http://ollama:11434
# Dacă Ollama rulează pe altă mașină din rețea:
# OLLAMA_URL=http://192.168.1.100:11434
OLLAMA_MODEL=qwen2.5vl:3b

# --- Memorie / Categorizare ---
MEMORY_DB_PATH=/app/data/memory.db

# --- General ---
DEFAULT_CURRENCY=EUR
TZ=Europe/Amsterdam
LOG_LEVEL=INFO
