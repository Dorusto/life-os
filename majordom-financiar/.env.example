# ============================================================
# Majordom Financiar — Configurare
# Copiază acest fișier ca .env și completează valorile
# ============================================================

# --- Telegram Bot ---
# Obține token de la @BotFather pe Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# ID-ul tău Telegram (pentru securitate - doar tu poți folosi botul)
# Trimite /start la @userinfobot pentru a-l afla
TELEGRAM_ALLOWED_USER_IDS=123456789

# --- Actual Budget ---
ACTUAL_BUDGET_URL=http://actual-budget:5006
ACTUAL_BUDGET_PASSWORD=your_password_here
ACTUAL_BUDGET_SYNC_ID=your_sync_id_here

# --- OCR ---
# Limba pentru Tesseract (ron = română, ron+eng = română + engleză)
TESSERACT_LANG=ron+eng
# Nivel de pre-procesare: 1=basic, 2=moderate, 3=aggressive
OCR_PREPROCESS_LEVEL=2

# --- Memorie / Învățare ---
# Pragul de confidență pentru categorizare automată (0.0 - 1.0)
CATEGORIZE_AUTO_THRESHOLD=0.8
# Calea bazei de date SQLite
MEMORY_DB_PATH=/app/data/memory.db

# --- General ---
DEFAULT_CURRENCY=RON
TZ=Europe/Bucharest
LOG_LEVEL=INFO
