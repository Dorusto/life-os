# ============================================================
# Majordom Financiar v2 — Configuration
# Copy this file as .env and fill in your values.
# Never commit .env to git — it contains secrets.
# ============================================================

# --- Web UI Authentication ---
# Two users are supported. Add more by following the USER1/USER2 pattern.
# Passwords are stored as plaintext here and hashed in memory at startup.
# Minimum recommended password length: 12 characters.

USER1_USERNAME=your_username
USER1_PASSWORD=change_me_please

USER2_USERNAME=partner_username   # optional — remove if not needed
USER2_PASSWORD=change_me_please   # optional

# JWT secret — used to sign login tokens.
# Generate a strong random value: python3 -c "import secrets; print(secrets.token_hex(32))"
# If this changes, all logged-in users will be logged out automatically.
JWT_SECRET=generate_a_random_secret_here

# Port for the web UI (default: 3000).
# Access the app at http://your-server-ip:3000 (or via Tailscale hostname).
WEB_PORT=3000

# --- Actual Budget ---
# URL is internal Docker network name — don't change unless you run Actual Budget separately
ACTUAL_BUDGET_URL=http://actual-budget:5006
ACTUAL_BUDGET_PASSWORD=your_actual_budget_password
# Sync ID: open Actual Budget → Settings → Advanced → Sync ID
ACTUAL_BUDGET_SYNC_ID=your_sync_id_here

# --- Ollama — choose ONE option, not both ---
#
# Option A — external Ollama server (recommended if you have a machine with GPU):
#   Set OLLAMA_URL to that machine's IP. Start with: docker compose up
#   Do NOT use --profile ollama-local with this option.
OLLAMA_URL=http://192.168.1.100:11434
#
# Option B — Ollama runs inside Docker on this host (CPU only, slower):
#   Comment out Option A above, uncomment the line below.
#   Start with: docker compose --profile ollama-local up -d
# OLLAMA_URL=http://ollama:11434
#
# Minimum model size for reliable tool calling: 7B.
# Models smaller than 7B will fail to use tools correctly.
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_CHAT_MODEL=qwen2.5:7b

# How long to keep models loaded after last use.
# Without this, both chat (~5GB) and vision (~6GB) stay in RAM simultaneously.
# On machines with 16GB RAM this forces ~3GB into swap. 5m = unload after 5 idle minutes.
OLLAMA_KEEP_ALIVE=5m

# --- Memory / Categorization ---
MEMORY_DB_PATH=/app/data/memory.db

# --- General ---
DEFAULT_CURRENCY=EUR
TZ=Europe/Amsterdam
LOG_LEVEL=INFO

# --- Telegram Bot (optional — only needed with --profile telegram) ---
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your Telegram user ID — only this ID can use the bot
# How to find it: send /start to @userinfobot on Telegram
# Multiple users: 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=123456789
